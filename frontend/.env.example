# Copy to .env (git-ignored) and adjust as needed.
#
# Base URL the frontend uses for API calls.
#  - Leave unset to use the relative '/api' path, which Vite proxies to the
#    local backend (http://localhost:3001) during `npm run dev`.
#  - Set to a deployed API Gateway base + '/api' to hit AWS directly:
VITE_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com/<stage>/api
